    {
      "parameters": {
        "jsCode": "const result = [];\n\n// Loop through every incoming item (usually just 1, but works for multiple)\nfor (const item of items) {\n  const dataArray = item.json.data || [];\n\n  // Loop through every object in data[] (data[0], data[1], data[2], ...)\n  dataArray.forEach(dataObj => {\n    const incidents = dataObj.incidents || [];\n\n    incidents.forEach(incident => {\n      result.push({\n        json: {\n          ID: incident.id,\n          Incident_NR: incident.incident_number,\n          Title: incident.title,\n          Service: incident.service.summary,\n          Created: incident.created_at,\n          Resolved: incident.resolved_at,\n          Status: incident.status,\n          Incident_url: incident.html_url\n        }\n      });\n    });\n  });\n}\n\nreturn result;"
      },
